NODE_ENV=production
PORT=8788
WEB_DIST_DIR=/app/dist/apps/web

# Public reverse proxy. Defaults avoid poly-elon ports on the same server.
SITE_DOMAIN=b.dark20.xyz
HTTP_PORT=8088
HTTPS_PORT=8444

# Live is the current production default. Use monitor for dry-run validation.
EXECUTION_MODE=live
# Per-profile status. BTC 5m follows EXECUTION_MODE by default; 15m/1h default
# to monitor for shadow validation. ETH/SOL profiles are code-defined but disabled.
BTC_5M_PROFILE_STATUS=live
BTC_15M_PROFILE_STATUS=monitor
BTC_1H_PROFILE_STATUS=monitor
# classic = current CHOP strategy with single-fill profit exit/hedge.
# experiment_next_round = fixed next-round UP 0.50 / DOWN 0.49 entries, no exits, stop after single.
ACTIVE_STRATEGY_PROFILE=classic
DASHBOARD_INTERNAL_API_KEY=
APP_VERSION=0.1.0
GIT_SHA=local
BUILD_TIME=local

POLYMARKET_CLOB_API_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_API_URL=https://data-api.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_DEPOSIT_WALLET=
OWNER_PRIVATE_KEY=

# BTC price comes from Binance public BTCUSDT aggTrade websocket.
BINANCE_BTC_WS_URL=wss://stream.binance.com:9443/ws/btcusdt@aggTrade
BINANCE_PRICE_SAMPLE_MS=1000
POLYMARKET_CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

BOT_TICK_MS=2000
RUNTIME_STATE_PATH=data/runtime-state.json
RUNTIME_MAX_RECORDS=1000

DUAL_LIMIT_PRICE=0.45
DYNAMIC_LIMIT_ENABLED=false
MIN_DYNAMIC_LIMIT_PRICE=0.42
MAX_DYNAMIC_LIMIT_PRICE=0.46
MAX_PAIR_COST=0.92
ORDER_SHARES_PER_SIDE=5
DYNAMIC_SHARES_ENABLED=false
MAX_ORDER_SHARES_PER_SIDE=6.25
MIN_ORDER_SHARES=5
MAX_ORDERBOOK_AGE_SECONDS=5

# Strategy thresholds are price dollars over the 120s/30s sampled Binance path.
MIN_CROSS_120S=2
MAX_ABS_DRIFT_120S=40
MAX_ABS_MOMENTUM_30S=28
# Dynamic BTC path thresholds. CHOP entry scores range, drift, and momentum,
# plus crosses/excursions around the recent 120s median price center.
MIN_CHOP_SCORE=70
MIN_RANGE_BPS_120S=3
MIN_BI_EXCURSION_BPS_120S=1
MAX_DRIFT_RATIO_120S=0.45
MAX_MOMENTUM_RATIO_30S=0.55
MAX_ENTRY_QUEUE_IMBALANCE=5
MIN_LIVE_CHOP_SCORE=70
BYPASS_ENTRY_SCORE_GATING=true
BYPASS_SINGLE_FILL_COOLDOWN=false
ENTRY_CONFIRM_TICKS=3
# Entry orders are GTC because short GTD expirations can be rejected by CLOB.
# The runtime stops submitting near start; post-start risk is handled by profit-exit/hedge rules.
ENTRY_MIN_SECONDS_TO_START=15

# PM data-api participation gate. Uses holders by conditionId plus limited
# per-holder positions lookups. Unavailable data is shown but does not block.
PARTICIPATION_ENABLED=true
PARTICIPATION_CACHE_MS=30000
PARTICIPATION_TOP_HOLDERS_PER_SIDE=8
MIN_PARTICIPATION_HOLDERS_PER_SIDE=3
MIN_PARTICIPATION_TOP_HOLDER_SHARES_PER_SIDE=300
MIN_PARTICIPATION_TOP_POSITION_PNL=40
MIN_PARTICIPATION_POSITION_PNL_SUM=100
MAX_PARTICIPATION_HOLDER_CONCENTRATION=0.75

# Adaptive pause after a final single-sided BUY fill. Successful hedges end paired
# and do not trigger this cooldown.
SINGLE_FILL_COOLDOWN_BASE_MS=900000
SINGLE_FILL_COOLDOWN_PRICE_CAP_MS=1800000
SINGLE_FILL_COOLDOWN_EXECUTION_MS=3600000
SINGLE_FILL_COOLDOWN_REPEAT_WINDOW_MS=3600000
SINGLE_FILL_COOLDOWN_SECOND_MS=3600000
SINGLE_FILL_COOLDOWN_THIRD_MS=3600000

# Three-stage single-fill hedge. From 60s to 30s remaining, the bot only hedges
# near breakeven. From 30s to 15s, it accepts the wider final risk cap. Inside
# the final 15s, emergency hedge can accept a larger locked loss to avoid
# carrying naked directional exposure into settlement.
# All paths submit capped aggressive FAK BUY limits, never uncapped markets.
SINGLE_FILL_HEDGE_ENABLED=true
SINGLE_FILL_EARLY_HEDGE_WINDOW_SECONDS=60
SINGLE_FILL_EARLY_HEDGE_MAX_PAIR_COST=1.02
SINGLE_FILL_EMERGENCY_HEDGE_WINDOW_SECONDS=15
SINGLE_FILL_EMERGENCY_HEDGE_MAX_PRICE=0.75
SINGLE_FILL_EMERGENCY_HEDGE_MAX_PAIR_COST=1.20
SINGLE_FILL_HEDGE_WINDOW_SECONDS=30
SINGLE_FILL_HEDGE_MIN_SECONDS_TO_END=5
SINGLE_FILL_HEDGE_MAX_PRICE=0.65
SINGLE_FILL_HEDGE_PRICE_OFFSET=0.01
SINGLE_FILL_HEDGE_MAX_PAIR_COST=1.10

# Single-fill profit exit. If the filled side can be sold for a configured
# profit while the missing side is still unfilled, cancel the missing-side BUY
# and submit a capped FAK SELL limit for the filled side.
SINGLE_FILL_PROFIT_EXIT_ENABLED=true
# Minimum profit rate on the filled side, e.g. 0.05 = 5%.
SINGLE_FILL_PROFIT_EXIT_MIN_RATE=0.05
SINGLE_FILL_PROFIT_EXIT_MIN_PRICE=0.50
SINGLE_FILL_PROFIT_EXIT_MIN_PNL_USD=0.30
SINGLE_FILL_PROFIT_EXIT_PRICE_OFFSET=0.01
SINGLE_FILL_PROFIT_EXIT_MAX_ORDERBOOK_AGE_MS=1000
SINGLE_FILL_PROFIT_EXIT_MIN_SECONDS_TO_END=20
SINGLE_FILL_PROFIT_EXIT_MAX_SECONDS_TO_END=240

# Experimental profile. Only used when ACTIVE_STRATEGY_PROFILE=experiment_next_round.
EXPERIMENT_NEXT_ROUND_UP_LIMIT_PRICE=0.50
EXPERIMENT_NEXT_ROUND_DOWN_LIMIT_PRICE=0.49
EXPERIMENT_NEXT_ROUND_SHARES_PER_SIDE=5
EXPERIMENT_STOP_ON_SINGLE=true

# Optional Telegram personal notifications. Balance is read only when a message
# is about to be sent, not on every bot tick.
TELEGRAM_NOTIFY_ENABLED=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_USER_ID=
TELEGRAM_ROUND_SUMMARY_ON_ORDER_ONLY=true
TELEGRAM_IDLE_SUMMARY_INTERVAL_MS=14400000
